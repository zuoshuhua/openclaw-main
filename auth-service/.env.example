# Database
DATABASE_URL="file:./data/auth.db"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Server
PORT=3002
NODE_ENV="development"

# Gateway
DEFAULT_GATEWAY_URL="ws://localhost:3001"

# Email (optional, for password reset)
# SMTP_HOST=""
# SMTP_PORT=""
# SMTP_USER=""
# SMTP_PASS=""
# FROM_EMAIL=""
