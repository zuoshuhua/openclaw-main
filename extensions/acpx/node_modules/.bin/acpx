#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/mnt/e/workplace/openclaw1-main/openclaw-main/node_modules/.pnpm/acpx@0.1.15_zod@4.3.6/node_modules/acpx/dist/node_modules:/mnt/e/workplace/openclaw1-main/openclaw-main/node_modules/.pnpm/acpx@0.1.15_zod@4.3.6/node_modules/acpx/node_modules:/mnt/e/workplace/openclaw1-main/openclaw-main/node_modules/.pnpm/acpx@0.1.15_zod@4.3.6/node_modules:/mnt/e/workplace/openclaw1-main/openclaw-main/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/mnt/e/workplace/openclaw1-main/openclaw-main/node_modules/.pnpm/acpx@0.1.15_zod@4.3.6/node_modules/acpx/dist/node_modules:/mnt/e/workplace/openclaw1-main/openclaw-main/node_modules/.pnpm/acpx@0.1.15_zod@4.3.6/node_modules/acpx/node_modules:/mnt/e/workplace/openclaw1-main/openclaw-main/node_modules/.pnpm/acpx@0.1.15_zod@4.3.6/node_modules:/mnt/e/workplace/openclaw1-main/openclaw-main/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../acpx/dist/cli.js" "$@"
else
  exec node  "$basedir/../acpx/dist/cli.js" "$@"
fi
